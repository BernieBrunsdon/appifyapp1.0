PORT=3002
# Set to 1 only when developing the app (register/login/dashboard) locally.
# Leave unset to preview marketing at http://localhost:3002
REACT_APP_APP_SHELL=1
# Local only. Production builds: omit this or use Render URL — app now ignores localhost API when not on localhost.
REACT_APP_API_URL=http://localhost:3001
# Signup/login live on app.appifyai.com (override for staging)
# REACT_APP_APP_ORIGIN=https://app.appifyai.com

# Google Calendar (required for calendar connection step)
# See docs/GOOGLE_CALENDAR_OAUTH_SETUP.md
# REACT_APP_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# REACT_APP_GOOGLE_API_KEY=AIzaSy...
